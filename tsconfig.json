{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/docs/*": ["./docs/*"],
      "@/components/audio-waveform": ["./registry/ikui/audio-waveform.tsx"],
      "@/components/cascader": ["./registry/ikui/cascader.tsx"],
      "@/components/chart": ["./registry/ikui/chart.tsx"],
      "@/components/copy-button": ["./registry/ikui/copy-button.tsx"],
      "@/components/heatmap-calendar": ["./registry/ikui/heatmap-calendar.tsx"],
      "@/components/image-compare": ["./registry/ikui/image-compare.tsx"],
      "@/components/image-crop": ["./registry/ikui/image-crop.tsx"],
      "@/components/image-grid": ["./registry/ikui/image-grid.tsx"],
      "@/components/particle-image": ["./registry/ikui/particle-image.tsx"],
      "@/components/password-input": ["./registry/ikui/password-input.tsx"],
      "@/components/qr-code": ["./registry/ikui/qr-code.tsx"],
      "@/components/segmented-timeline-strip": [
        "./registry/ikui/segmented-timeline-strip.tsx"
      ],
      "@/components/spark-chart": ["./registry/ikui/spark-chart.tsx"],
      "@/components/thumbnail-strip": ["./registry/ikui/thumbnail-strip.tsx"],
      "@/components/timeline-element": ["./registry/ikui/timeline-element.tsx"],
      "@/components/timeline-playhead": [
        "./registry/ikui/timeline-playhead.tsx"
      ],
      "@/components/timeline-ruler": ["./registry/ikui/timeline-ruler.tsx"],
      "@/components/tree": ["./registry/ikui/tree.tsx"],
      "@/lib/video-thumbnail-cache": [
        "./registry/ikui/video-thumbnail-cache.ts"
      ],
      "@/components/waveform-player": ["./registry/ikui/waveform-player.tsx"],
      "@/*": ["./src/*", "./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "src/components/signature.tsx",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules", "tmp"]
}
