{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/docs/*": ["./docs/*"],
      "@/components/audio-waveform": ["./registry/ikui/audio-waveform.tsx"],
      "@/components/timeline-ruler": ["./registry/ikui/timeline-ruler.tsx"],
      "@/components/timeline-element": ["./registry/ikui/timeline-element.tsx"],
      "@/components/timeline-playhead": [
        "./registry/ikui/timeline-playhead.tsx"
      ],
      "@/components/thumbnail-strip": ["./registry/ikui/thumbnail-strip.tsx"],
      "@/lib/video-thumbnail-cache": [
        "./registry/ikui/video-thumbnail-cache.ts"
      ],
      "@/*": ["./src/*", "./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "src/components/signature.tsx",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules", "tmp"]
}
